-- ──────────────────────────────────────────────────────────────────────
-- Service & Controller Definitions
-- ──────────────────────────────────────────────────────────────────────

--- The context object passed to `Init()` and `Start()` lifecycle methods.
export type ContextType = {
	--- A tag-scoped logger for this service/controller.
	Log: TaggedLogger,
	--- Reference to the Kore API.
	Kore: KoreAPI,
	--- The service/controller's Config table, if any.
	Config: { [string]: any }?,
}

--- Client-facing table on a service, defining remote methods and events.
export type ClientTable = {
	--- Per-remote middleware definitions.
	Middleware: { [string]: MiddlewareDef }?,
	--- Per-remote rate-limit definitions.
	RateLimit: { [string]: RateLimitConfig }?,
	--- Batching configuration.
	Batching: any?,
	--- Additional remote methods/events indexed by name.
	[string]: ((...any) -> ...any) | NetEventType | {
		fn: (...any) -> ...any,
		Unreliable: boolean?,
		Immediate: boolean?,
	},
}

-- ──────────────────────────────────────────────────────────────────────
-- Service & Controller Injected Fields (for CreateService / CreateController)
-- ──────────────────────────────────────────────────────────────────────

--- Fields injected by `Kore.CreateService()`. Used as the intersection return type
--- so that `self` in `:` methods gets full IntelliSense on Janitor, Log, etc.
export type ServiceFields = {
	Janitor: Janitor,
	Log: TaggedLogger,
	FireClient: ((self: any, eventName: string, player: Player, ...any) -> ())?,
	FireAllClients: ((self: any, eventName: string, ...any) -> ())?,
}

--- Fields injected by `Kore.CreateController()`. Used as the intersection return type
--- so that `self` in `:` methods gets full IntelliSense on Janitor, Log, etc.
export type ControllerFields = {
	Janitor: Janitor,
	Log: TaggedLogger,
}

--- A Kore service definition table.
export type ServiceDefinition = {
	--- Unique name for this service.
	Name: string,
	--- List of service names this service depends on (for load ordering).
	Dependencies: { string }?,
	--- Arbitrary configuration data.
	Config: { [string]: any }?,
	--- Client-facing remotes table.
	Client: ClientTable?,
	--- Called synchronously in dependency order. Must not yield.
	Init: ((self: ServiceDefinition, ctx: ContextType) -> ())?,
	--- Called concurrently after all Init() calls complete. May yield.
	Start: ((self: ServiceDefinition, ctx: ContextType) -> ())?,
	--- Called when the service is dynamically destroyed.
	Destroy: ((self: ServiceDefinition) -> ())?,
	--- Auto-injected Janitor for deterministic cleanup.
	Janitor: Janitor,
	--- Auto-injected tagged logger.
	Log: TaggedLogger,
	--- Fire a named event to a specific client.
	FireClient: ((self: ServiceDefinition, eventName: string, player: Player, ...any) -> ())?,
	--- Fire a named event to all clients.
	FireAllClients: ((self: ServiceDefinition, eventName: string, ...any) -> ())?,
	--- Additional user-defined fields.
	[any]: any,
}

--- A Kore controller definition table.
export type ControllerDefinition = {
	--- Unique name for this controller.
	Name: string,
	--- List of controller/service names this controller depends on.
	Dependencies: { string }?,
	--- Arbitrary configuration data.
	Config: { [string]: any }?,
	--- Called synchronously in dependency order. Must not yield.
	Init: ((self: ControllerDefinition, ctx: ContextType) -> ())?,
	--- Called concurrently after all Init() calls complete. May yield.
	Start: ((self: ControllerDefinition, ctx: ContextType) -> ())?,
	--- Called when the controller is dynamically destroyed.
	Destroy: ((self: ControllerDefinition) -> ())?,
	--- Auto-injected Janitor for deterministic cleanup.
	Janitor: Janitor,
	--- Auto-injected tagged logger.
	Log: TaggedLogger,
	--- Additional user-defined fields.
	[any]: any,
}

-- ──────────────────────────────────────────────────────────────────────
-- Kore API
-- ──────────────────────────────────────────────────────────────────────

--- The main Kore framework API.
export type KoreAPI = {
	--- Sentinel symbol for server-to-client event remotes.
	NetEvent: Symbol,

	-- Re-exported modules
	Promise: any,
	Signal: SignalModule,
	Log: LogModule,
	Timer: TimerModule,
	Symbol: SymbolConstructor,
	Tween: TweenModule,
	Curve: CurveModule,
	Data: DataModule,
	Thread: ThreadModule,
	Mock: MockModule,
	Janitor: JanitorModule,
	Util: UtilModule,
	Net: NetModule,
	Types: any,
	Fusion: any?,

	--- Set framework configuration. Must be called before `Start()`.
	Configure: (config: KoreConfig) -> (),
	--- Register a service (server only).
	AddService: (serviceTable: ServiceDefinition) -> (),
	--- Register a controller (client only).
	AddController: (controllerTable: ControllerDefinition) -> (),
	--- Create and register a service with full IntelliSense. Returns T & ServiceFields.
	CreateService: <T>(serviceTable: T & { Name: string }) -> T & ServiceFields,
	--- Create and register a controller with full IntelliSense. Returns T & ControllerFields.
	CreateController: <T>(controllerTable: T & { Name: string }) -> T & ControllerFields,
	--- Retrieve a registered service by name. On the client, returns a network proxy.
	GetService: (name: string) -> ServiceDefinition,
	--- Retrieve a registered controller by name (client only).
	GetController: (name: string) -> ControllerDefinition,
	--- Boot the framework. Returns a Promise that resolves when all lifecycle methods complete.
	Start: () -> any, -- Promise<void>
	--- Dynamically destroy and unregister a service. Requires `Destroy = "dynamic"` config.
	DestroyService: (name: string) -> (),
	--- Dynamically destroy and unregister a controller. Requires `Destroy = "dynamic"` config.
	DestroyController: (name: string) -> (),
}

